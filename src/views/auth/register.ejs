<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-auth-body">
    <%- include('../partials/navbar') %>

    <main class="mf-auth-main">
      <div class="mf-auth-layout">
        <section class="mf-auth-intro" aria-labelledby="registerIntroTitle">
          <span class="mf-auth-intro__eyebrow">Comienza con una base financiera clara</span>
          <h1 id="registerIntroTitle">Organiza hoy lo que quieres construir mañana.</h1>
          <p>
            Crea tu cuenta y administra tus finanzas personales o compartidas desde espacios
            independientes, seguros y fáciles de entender.
          </p>
          <ul class="mf-auth-features">
            <li>Espacios separados para finanzas personales y familiares</li>
            <li>Cuentas, categorías y permisos centralizados</li>
            <li>Protección con contraseña robusta y MFA opcional</li>
          </ul>
        </section>

        <section class="mf-auth-card" aria-labelledby="registerTitle">
          <div class="mf-auth-card__body">
            <span class="mf-auth-card__badge">Nueva cuenta</span>
            <h1 id="registerTitle">Crear cuenta</h1>
            <p class="mf-auth-card__subtitle">Completa tus datos para comenzar a organizar tus finanzas.</p>

            <% if (formError) { %>
              <div class="mf-auth-alert" role="alert"><%= formError %></div>
            <% } %>

            <form class="mf-auth-form" method="post" action="/auth/register" novalidate>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

              <div class="mf-auth-field">
                <label for="name">Nombre</label>
                <input
                  class="mf-auth-input <%= fieldErrors.name ? 'is-invalid' : '' %>"
                  id="name"
                  name="name"
                  type="text"
                  minlength="2"
                  maxlength="100"
                  autocomplete="name"
                  value="<%= values.name %>"
                  required
                />
                <% if (fieldErrors.name) { %><p class="mf-auth-error"><%= fieldErrors.name %></p><% } %>
              </div>

              <div class="mf-auth-field">
                <label for="email">Correo electrónico</label>
                <input
                  class="mf-auth-input <%= fieldErrors.email ? 'is-invalid' : '' %>"
                  id="email"
                  name="email"
                  type="email"
                  maxlength="254"
                  autocomplete="email"
                  value="<%= values.email %>"
                  required
                />
                <% if (fieldErrors.email) { %><p class="mf-auth-error"><%= fieldErrors.email %></p><% } %>
              </div>

              <div class="mf-auth-field">
                <label for="password">Contraseña</label>
                <input
                  class="mf-auth-input <%= fieldErrors.password ? 'is-invalid' : '' %>"
                  id="password"
                  name="password"
                  type="password"
                  minlength="12"
                  maxlength="128"
                  autocomplete="new-password"
                  aria-describedby="passwordHelp"
                  required
                />
                <p class="mf-auth-help" id="passwordHelp">Usa al menos 12 caracteres.</p>
                <% if (fieldErrors.password) { %><p class="mf-auth-error"><%= fieldErrors.password %></p><% } %>
              </div>

              <div class="mf-auth-field">
                <label for="passwordConfirmation">Confirmar contraseña</label>
                <input
                  class="mf-auth-input <%= fieldErrors.passwordConfirmation ? 'is-invalid' : '' %>"
                  id="passwordConfirmation"
                  name="passwordConfirmation"
                  type="password"
                  minlength="12"
                  maxlength="128"
                  autocomplete="new-password"
                  required
                />
                <% if (fieldErrors.passwordConfirmation) { %><p class="mf-auth-error"><%= fieldErrors.passwordConfirmation %></p><% } %>
              </div>

              <button class="mf-auth-submit" type="submit">Crear cuenta</button>
            </form>

            <p class="mf-auth-switch">
              ¿Ya tienes una cuenta? <a href="/auth/login">Iniciar sesión</a>
            </p>
          </div>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
