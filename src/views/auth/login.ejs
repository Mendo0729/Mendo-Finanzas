<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-auth-body">
    <%- include('../partials/navbar') %>

    <main class="mf-auth-main">
      <div class="mf-auth-layout">
        <section class="mf-auth-intro" aria-labelledby="loginIntroTitle">
          <span class="mf-auth-intro__eyebrow">Control financiero personal y compartido</span>
          <h1 id="loginIntroTitle">Tus finanzas, en un solo lugar.</h1>
          <p>
            Consulta cuentas, presupuestos y movimientos con una experiencia clara, segura y
            diseñada para ayudarte a tomar mejores decisiones.
          </p>
          <ul class="mf-auth-features">
            <li>Información organizada por espacio financiero</li>
            <li>Acceso protegido y verificación en dos pasos</li>
            <li>Resumen visual para entender tus números rápidamente</li>
          </ul>
        </section>

        <section class="mf-auth-card" aria-labelledby="loginTitle">
          <div class="mf-auth-card__body">
            <span class="mf-auth-card__badge">Acceso seguro</span>
            <h1 id="loginTitle">Iniciar sesión</h1>
            <p class="mf-auth-card__subtitle">Accede a tu espacio financiero y continúa donde lo dejaste.</p>

            <% if (formError) { %>
              <div class="mf-auth-alert" role="alert"><%= formError %></div>
            <% } %>

            <form class="mf-auth-form" method="post" action="/auth/login" novalidate>
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

              <div class="mf-auth-field">
                <label for="email">Correo electrónico</label>
                <input
                  class="mf-auth-input <%= fieldErrors.email ? 'is-invalid' : '' %>"
                  id="email"
                  name="email"
                  type="email"
                  maxlength="254"
                  autocomplete="email"
                  value="<%= values.email %>"
                  required
                />
                <% if (fieldErrors.email) { %>
                  <p class="mf-auth-error"><%= fieldErrors.email %></p>
                <% } %>
              </div>

              <div class="mf-auth-field">
                <label for="password">Contraseña</label>
                <input
                  class="mf-auth-input <%= fieldErrors.password ? 'is-invalid' : '' %>"
                  id="password"
                  name="password"
                  type="password"
                  maxlength="128"
                  autocomplete="current-password"
                  required
                />
                <% if (fieldErrors.password) { %>
                  <p class="mf-auth-error"><%= fieldErrors.password %></p>
                <% } %>
              </div>

              <button class="mf-auth-submit" type="submit">Iniciar sesión</button>
            </form>

            <p class="mf-auth-switch">
              ¿No tienes una cuenta? <a href="/auth/register">Crear cuenta</a>
            </p>
          </div>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
