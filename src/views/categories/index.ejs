<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-app-body">
    <div class="mf-workspace-shell">
      <%- include('../partials/app-sidebar', { activeSection: 'categories' }) %>
      <button
        class="mf-sidebar-backdrop"
        type="button"
        data-sidebar-close
        aria-label="Cerrar menú"
      ></button>

      <main class="mf-workspace-main">
        <%- include('../partials/app-header', {
          headerEyebrow: 'Administración',
          headerTitle: 'Categorías',
          primaryAction: householdPermissions.includes('categories:manage')
            ? { href: '/categories/new', label: 'Nueva categoría' }
            : null,
        }) %>

        <div class="mf-workspace-content">
          <div class="mf-page-intro">
            <div>
              <span class="mf-page-kicker">Organización</span>
              <h2>Categorías financieras</h2>
              <p>Clasifica ingresos y gastos para entender mejor el uso de tu dinero.</p>
            </div>
          </div>

          <% if (categories.length > 0) { %>
            <section class="mf-data-table-wrap" aria-label="Listado de categorías">
              <table class="mf-data-table">
                <thead>
                  <tr>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Uso</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <% categories.forEach((category) => { %>
                    <tr>
                      <td>
                        <div class="mf-data-table__title">
                          <span
                            class="mf-category-marker <%= Number(category.categoryType) === 2 ? 'mf-category-marker--expense' : '' %>"
                            aria-hidden="true"
                          ></span>
                          <span><%= category.name %></span>
                          <% if (category.isDefault) { %>
                            <span class="mf-badge">Predeterminada</span>
                          <% } %>
                        </div>
                      </td>
                      <td><%= category.categoryTypeLabel %></td>
                      <td>
                        <%= category.transactionCount %> movimientos · <%= category.budgetCount %>
                        presupuestos
                      </td>
                      <td>
                        <span
                          class="mf-badge <%= category.active ? 'mf-badge--success' : 'mf-badge--danger' %>"
                        >
                          <%= category.active ? 'Activa' : 'Inactiva' %>
                        </span>
                      </td>
                      <td>
                        <% if (householdPermissions.includes('categories:manage')) { %>
                          <div class="mf-table-actions">
                            <a
                              class="mf-small-button mf-small-button--primary"
                              href="/categories/<%= category.id %>/edit"
                            >
                              Editar
                            </a>
                            <% if (!category.isDefault) { %>
                              <form method="post" action="/categories/<%= category.id %>/status">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                <input
                                  type="hidden"
                                  name="active"
                                  value="<%= category.active ? 'false' : 'true' %>"
                                />
                                <button class="mf-small-button" type="submit">
                                  <%= category.active ? 'Desactivar' : 'Activar' %>
                                </button>
                              </form>
                            <% } %>
                          </div>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </section>
          <% } else { %>
            <section class="mf-empty-state">
              <h2 class="h5">Aún no hay categorías</h2>
              <p class="mb-0">Crea una categoría para organizar tus próximos movimientos.</p>
            </section>
          <% } %>
        </div>
      </main>
    </div>
  </body>
</html>
