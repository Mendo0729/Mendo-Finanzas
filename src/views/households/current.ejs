<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="bg-body-tertiary min-vh-100 d-flex flex-column">
    <%- include('../partials/navbar') %>

    <main class="container py-5 flex-grow-1">
      <div class="row g-4">
        <div class="col-lg-5">
          <section class="rounded-4 bg-white p-4 shadow-sm h-100">
            <span class="badge text-bg-success mb-3">Espacio activo</span>
            <h1 class="h2"><%= household.name %></h1>
            <p class="text-body-secondary">
              Este contexto se aplicará a todas las consultas financieras protegidas.
            </p>

            <dl class="row mb-4">
              <dt class="col-sm-5">Moneda</dt>
              <dd class="col-sm-7"><%= household.currency %></dd>

              <dt class="col-sm-5">Rol</dt>
              <dd class="col-sm-7"><span class="badge text-bg-primary"><%= role.label %></span></dd>

              <dt class="col-sm-5">Miembro desde</dt>
              <dd class="col-sm-7"><%= joinedAt.toLocaleDateString('es-PA') %></dd>
            </dl>

            <div class="d-flex flex-wrap gap-2">
              <a class="btn btn-primary" href="/households/select">Cambiar espacio</a>
              <% if (householdPermissions.includes('household:update')) { %>
                <a class="btn btn-outline-primary" href="/households/<%= household.id %>/edit">
                  Editar espacio
                </a>
              <% } %>
              <a class="btn btn-outline-secondary" href="/">Volver al inicio</a>
            </div>
          </section>
        </div>

        <div class="col-lg-7">
          <section class="rounded-4 bg-white p-4 shadow-sm h-100">
            <h2 class="h4">Permisos efectivos</h2>
            <p class="text-body-secondary">
              Los permisos se calculan desde tu rol actual en cada solicitud.
            </p>

            <ul class="list-group list-group-flush">
              <% permissions.forEach((permission) => { %>
                <li class="list-group-item px-0 d-flex justify-content-between gap-3">
                  <span><%= permission.label %></span>
                  <code><%= permission.key %></code>
                </li>
              <% }) %>
            </ul>
          </section>
        </div>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
