<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="bg-body-tertiary min-vh-100 d-flex flex-column">
    <%- include('../partials/navbar') %>

    <main class="container py-5 flex-grow-1">
      <section class="card border-0 shadow-sm mx-auto" style="max-width: 34rem">
        <div class="card-body p-4 p-md-5">
          <h1 class="h2 mb-3">Crear cuenta</h1>
          <p class="text-body-secondary">Comienza a organizar tus finanzas personales.</p>

          <% if (formError) { %>
            <div class="alert alert-danger" role="alert"><%= formError %></div>
          <% } %>

          <form method="post" action="/auth/register" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

            <div class="mb-3">
              <label class="form-label" for="name">Nombre</label>
              <input
                class="form-control <%= fieldErrors.name ? 'is-invalid' : '' %>"
                id="name"
                name="name"
                type="text"
                minlength="2"
                maxlength="100"
                autocomplete="name"
                value="<%= values.name %>"
                required
              />
              <% if (fieldErrors.name) { %>
                <div class="invalid-feedback"><%= fieldErrors.name %></div>
              <% } %>
            </div>

            <div class="mb-3">
              <label class="form-label" for="email">Correo electrónico</label>
              <input
                class="form-control <%= fieldErrors.email ? 'is-invalid' : '' %>"
                id="email"
                name="email"
                type="email"
                maxlength="254"
                autocomplete="email"
                value="<%= values.email %>"
                required
              />
              <% if (fieldErrors.email) { %>
                <div class="invalid-feedback"><%= fieldErrors.email %></div>
              <% } %>
            </div>

            <div class="mb-3">
              <label class="form-label" for="password">Contraseña</label>
              <input
                class="form-control <%= fieldErrors.password ? 'is-invalid' : '' %>"
                id="password"
                name="password"
                type="password"
                minlength="12"
                maxlength="128"
                autocomplete="new-password"
                aria-describedby="passwordHelp"
                required
              />
              <div class="form-text" id="passwordHelp">Usa al menos 12 caracteres.</div>
              <% if (fieldErrors.password) { %>
                <div class="invalid-feedback"><%= fieldErrors.password %></div>
              <% } %>
            </div>

            <div class="mb-4">
              <label class="form-label" for="passwordConfirmation">Confirmar contraseña</label>
              <input
                class="form-control <%= fieldErrors.passwordConfirmation ? 'is-invalid' : '' %>"
                id="passwordConfirmation"
                name="passwordConfirmation"
                type="password"
                minlength="12"
                maxlength="128"
                autocomplete="new-password"
                required
              />
              <% if (fieldErrors.passwordConfirmation) { %>
                <div class="invalid-feedback"><%= fieldErrors.passwordConfirmation %></div>
              <% } %>
            </div>

            <button class="btn btn-primary w-100" type="submit">Crear cuenta</button>
          </form>

          <p class="text-center text-body-secondary mt-4 mb-0">
            ¿Ya tienes una cuenta? <a href="/auth/login">Iniciar sesión</a>
          </p>
        </div>
      </section>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
