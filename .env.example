NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

POSTGRES_DB=mendo_finanzas_dev
POSTGRES_USER=mendo_dev
POSTGRES_PASSWORD=change_this_local_password
POSTGRES_PORT=55433

DATABASE_URL=postgresql://mendo_dev:change_this_local_password@localhost:55433/mendo_finanzas_dev?schema=public
SESSION_SECRET=change_this_with_a_random_secret_of_at_least_32_characters

# Genera una clave de 32 bytes en Base64 con:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
MFA_ENCRYPTION_KEY=replace_with_a_32_byte_base64_key

# Opcionales en desarrollo y obligatorias en producción.
# Cuando ambas estén configuradas, los correos se envían mediante Resend.
RESEND_API_KEY=
EMAIL_FROM=
# Ejemplo: EMAIL_FROM="SharedWallet <no-reply@mail.example.com>"
