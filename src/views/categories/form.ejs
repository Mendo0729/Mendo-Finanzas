<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-app-body">
    <div class="mf-workspace-shell">
      <%- include('../partials/app-sidebar', { activeSection: 'categories' }) %>
      <button
        class="mf-sidebar-backdrop"
        type="button"
        data-sidebar-close
        aria-label="Cerrar menú"
      ></button>

      <main class="mf-workspace-main">
        <%- include('../partials/app-header', {
          headerEyebrow: 'Categorías',
          headerTitle: pageTitle,
          primaryAction: null,
        }) %>

        <div class="mf-workspace-content">
          <div class="mf-form-shell">
            <section class="mf-form-panel">
              <div class="mf-form-panel__header">
                <span class="mf-page-kicker">Clasificación financiera</span>
                <h2><%= pageTitle %></h2>
                <p>Organiza tus movimientos con un nombre, tipo e icono fáciles de reconocer.</p>
              </div>

              <% if (category?.isDefault) { %>
                <div class="mf-inline-note mb-4">
                  Esta categoría es predeterminada. Puedes cambiar su nombre o icono, pero no su
                  tipo ni desactivarla.
                </div>
              <% } %>

              <form method="post" action="<%= action %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

                <div class="mf-form-grid">
                  <div class="mf-form-field mf-form-field--7">
                    <label for="name">Nombre</label>
                    <input
                      class="mf-input"
                      id="name"
                      name="name"
                      maxlength="60"
                      required
                      value="<%= values.name %>"
                    />
                  </div>

                  <div class="mf-form-field mf-form-field--5">
                    <label for="categoryType">Tipo</label>
                    <select
                      class="mf-select"
                      id="categoryType"
                      name="categoryType"
                      required
                      <%= category?.isDefault ? 'disabled' : '' %>
                    >
                      <% categoryTypes.forEach((type) => { %>
                        <option
                          value="<%= type.value %>"
                          <%= Number(values.categoryType) === type.value ? 'selected' : '' %>
                        >
                          <%= type.label %>
                        </option>
                      <% }) %>
                    </select>
                    <% if (category?.isDefault) { %>
                      <input
                        type="hidden"
                        name="categoryType"
                        value="<%= values.categoryType %>"
                      />
                    <% } %>
                  </div>

                  <div class="mf-form-field">
                    <label for="icon">Icono</label>
                    <input
                      class="mf-input"
                      id="icon"
                      name="icon"
                      maxlength="40"
                      value="<%= values.icon %>"
                      placeholder="Ejemplo: home, car, briefcase"
                    />
                    <p class="mf-field-help">
                      Usa un nombre corto que represente visualmente la categoría.
                    </p>
                  </div>
                </div>

                <div class="mf-form-actions">
                  <button class="mf-button mf-button--primary" type="submit">
                    Guardar categoría
                  </button>
                  <a class="mf-button mf-button--ghost" href="/categories">Cancelar</a>
                </div>
              </form>
            </section>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
