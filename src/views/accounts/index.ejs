<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="bg-body-tertiary min-vh-100 d-flex flex-column">
    <%- include('../partials/navbar') %>
    <main class="container py-5 flex-grow-1">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
          <h1 class="h2 mb-1">Cuentas</h1>
          <p class="text-body-secondary mb-0">Administra las cuentas del espacio activo.</p>
        </div>
        <% if (householdPermissions.includes('accounts:manage')) { %>
          <a class="btn btn-primary" href="/accounts/new">Nueva cuenta</a>
        <% } %>
      </div>

      <div class="row g-3">
        <% accounts.forEach((account) => { %>
          <div class="col-md-6 col-xl-4">
            <article class="card h-100 shadow-sm border-0">
              <div class="card-body">
                <div class="d-flex justify-content-between gap-3">
                  <h2 class="h5"><%= account.name %></h2>
                  <span class="badge <%= account.active ? 'text-bg-success' : 'text-bg-secondary' %>">
                    <%= account.active ? 'Activa' : 'Inactiva' %>
                  </span>
                </div>
                <p class="text-body-secondary"><%= account.accountTypeLabel %></p>
                <dl class="row small mb-3">
                  <dt class="col-6">Moneda</dt><dd class="col-6"><%= account.currency %></dd>
                  <dt class="col-6">Saldo inicial</dt><dd class="col-6"><%= account.initialBalance %></dd>
                  <dt class="col-6">Movimientos</dt><dd class="col-6"><%= account.transactionCount %></dd>
                </dl>
                <% if (householdPermissions.includes('accounts:manage')) { %>
                  <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-outline-primary btn-sm" href="/accounts/<%= account.id %>/edit">Editar</a>
                    <form method="post" action="/accounts/<%= account.id %>/status">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <input type="hidden" name="active" value="<%= account.active ? 'false' : 'true' %>" />
                      <button class="btn btn-outline-secondary btn-sm" type="submit">
                        <%= account.active ? 'Desactivar' : 'Activar' %>
                      </button>
                    </form>
                  </div>
                <% } %>
              </div>
            </article>
          </div>
        <% }) %>
      </div>
      <% if (accounts.length === 0) { %>
        <div class="alert alert-info">Este espacio todavía no tiene cuentas.</div>
      <% } %>
    </main>
    <%- include('../partials/footer') %>
  </body>
</html>
