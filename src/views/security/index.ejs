<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-app-body">
    <div class="mf-workspace-shell">
      <%- include('../partials/app-sidebar', { activeSection: 'security' }) %>
      <button
        class="mf-sidebar-backdrop"
        type="button"
        data-sidebar-close
        aria-label="Cerrar menú"
      ></button>

      <main class="mf-workspace-main">
        <%- include('../partials/app-header', {
          headerEyebrow: 'Cuenta',
          headerTitle: 'Seguridad',
          primaryAction: !mfa.enabled
            ? { href: '/security/mfa/setup', label: 'Configurar MFA' }
            : null,
        }) %>

        <div class="mf-workspace-content">
          <div class="mf-page-intro">
            <div>
              <span class="mf-page-kicker">Protección de acceso</span>
              <h2>Seguridad de la cuenta</h2>
              <p>Administra la autenticación en dos pasos y tus códigos de recuperación.</p>
            </div>
          </div>

          <% if (successMessage) { %>
            <div class="mf-alert mf-alert--success mb-3" role="status">
              <%= successMessage %>
            </div>
          <% } %>
          <% if (formError) { %>
            <div class="mf-alert mf-alert--danger mb-3" role="alert"><%= formError %></div>
          <% } %>

          <section class="mf-security-layout">
            <article class="mf-page-card mf-security-status">
              <div>
                <span class="mf-page-kicker">Estado actual</span>
                <h3>Autenticación en dos pasos</h3>
                <% if (mfa.enabled) { %>
                  <p>
                    Activada el <%= mfa.enabledAt.toLocaleDateString('es-PA') %>. Códigos de
                    recuperación disponibles: <strong><%= mfa.unusedRecoveryCodes %></strong>.
                  </p>
                <% } else { %>
                  <p>
                    Añade una segunda capa de protección compatible con Google Authenticator y
                    Microsoft Authenticator.
                  </p>
                <% } %>
              </div>
              <span class="mf-badge <%= mfa.enabled ? 'mf-badge--success' : 'mf-badge--danger' %>">
                <%= mfa.enabled ? 'Habilitada' : 'Desactivada' %>
              </span>
            </article>

            <% if (mfa.enabled) { %>
              <article class="mf-page-card mf-security-card">
                <h3>Regenerar códigos de recuperación</h3>
                <p>Los códigos anteriores dejarán de funcionar inmediatamente.</p>
                <form method="post" action="/security/mfa/recovery-codes/regenerate">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <div class="mf-form-field">
                    <label for="regenerate-password">Contraseña actual</label>
                    <input
                      class="mf-input"
                      id="regenerate-password"
                      name="password"
                      type="password"
                      autocomplete="current-password"
                      maxlength="128"
                      required
                    />
                  </div>
                  <button class="mf-button mf-button--ghost" type="submit">
                    Generar nuevos códigos
                  </button>
                </form>
              </article>

              <article class="mf-page-card mf-security-card mf-security-card--danger">
                <h3>Desactivar MFA</h3>
                <p>Tu cuenta volverá a depender solamente del correo y la contraseña.</p>
                <form method="post" action="/security/mfa/disable">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <div class="mf-form-field">
                    <label for="disable-password">Contraseña actual</label>
                    <input
                      class="mf-input"
                      id="disable-password"
                      name="password"
                      type="password"
                      autocomplete="current-password"
                      maxlength="128"
                      required
                    />
                  </div>
                  <button class="mf-button mf-button--danger-ghost" type="submit">
                    Desactivar autenticación en dos pasos
                  </button>
                </form>
              </article>
            <% } else { %>
              <article class="mf-page-card mf-security-card">
                <h3>Configura tu aplicación de autenticación</h3>
                <p>
                  Escanearás un código QR y confirmarás la configuración con un código temporal.
                </p>
                <div class="mf-form-actions">
                  <a class="mf-button mf-button--primary" href="/security/mfa/setup">
                    Configurar Authenticator
                  </a>
                </div>
              </article>
            <% } %>
          </section>
        </div>
      </main>
    </div>
  </body>
</html>
