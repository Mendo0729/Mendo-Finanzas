<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-app-body">
    <div class="mf-workspace-shell">
      <%- include('../partials/app-sidebar', { activeSection: 'household' }) %>
      <button
        class="mf-sidebar-backdrop"
        type="button"
        data-sidebar-close
        aria-label="Cerrar menú"
      ></button>

      <main class="mf-workspace-main">
        <%- include('../partials/app-header', {
          headerEyebrow: 'Contexto financiero',
          headerTitle: 'Seleccionar espacio',
          primaryAction: { href: '/households/new', label: 'Crear espacio' },
        }) %>

        <div class="mf-workspace-content">
          <div class="mf-form-shell">
            <section class="mf-form-panel">
              <div class="mf-form-panel__header">
                <span class="mf-page-kicker">Contexto financiero</span>
                <h2>Selecciona un espacio</h2>
                <p>
                  Las cuentas, categorías, movimientos y presupuestos se limitarán al espacio
                  que elijas como activo.
                </p>
              </div>

              <% if (households.length === 0) { %>
                <div class="mf-empty-state">
                  <h3 class="h5">Tu cuenta aún no tiene espacios financieros</h3>
                  <p>Crea el primero para comenzar a registrar cuentas y movimientos.</p>
                  <a class="mf-button mf-button--primary" href="/households/new">
                    Crear mi primer espacio
                  </a>
                </div>
              <% } else { %>
                <form method="post" action="/households/select">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

                  <div class="mf-household-list">
                    <% households.forEach((household, index) => { %>
                      <label class="mf-household-option">
                        <input
                          type="radio"
                          name="householdId"
                          value="<%= household.id %>"
                          <%= household.id === selectedHouseholdId || (!selectedHouseholdId && index === 0) ? 'checked' : '' %>
                          required
                        />
                        <span class="mf-household-option__content">
                          <span class="mf-household-option__title">
                            <strong><%= household.name %></strong>
                            <span class="mf-badge"><%= household.role.label %></span>
                            <% if (household.id === selectedHouseholdId) { %>
                              <span class="mf-badge mf-badge--success">Activo</span>
                            <% } %>
                          </span>
                          <span>Moneda: <%= household.currency %></span>
                        </span>
                      </label>
                    <% }) %>
                  </div>

                  <div class="mf-form-actions">
                    <button class="mf-button mf-button--primary" type="submit">
                      Usar este espacio
                    </button>
                    <a class="mf-button mf-button--ghost" href="/households/new">
                      Crear otro espacio
                    </a>
                    <a class="mf-button mf-button--ghost" href="/">Volver al dashboard</a>
                  </div>
                </form>
              <% } %>
            </section>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
