<!doctype html>
<html lang="es">
  <%- include('partials/head') %>
  <body class="bg-body-tertiary min-vh-100 d-flex flex-column">
    <%- include('partials/navbar') %>

    <main class="container py-5 flex-grow-1">
      <section class="rounded-4 bg-white p-4 p-md-5 shadow-sm">
        <span class="badge text-bg-primary mb-3">Entorno inicial</span>
        <h1 class="display-5 fw-bold">Mendo Finanzas</h1>
        <p class="lead">
          La estructura Node.js, Express, EJS, Prisma y PostgreSQL está preparada.
        </p>

        <dl class="row mb-4">
          <dt class="col-sm-3">Aplicación</dt>
          <dd class="col-sm-9 text-success">Activa</dd>

          <dt class="col-sm-3">Base de datos</dt>
          <dd class="col-sm-9">
            <span class="badge <%= databaseStatus === 'up' ? 'text-bg-success' : 'text-bg-danger' %>">
              <%= databaseStatus === 'up' ? 'Disponible' : 'No disponible' %>
            </span>
          </dd>

          <dt class="col-sm-3">Entorno</dt>
          <dd class="col-sm-9"><code><%= environment %></code></dd>
        </dl>

        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-primary" href="/health">Consultar healthcheck</a>
          <a
            class="btn btn-outline-secondary"
            href="https://github.com/Mendo0729/Mendo-Finanzas"
            target="_blank"
            rel="noreferrer"
          >
            Ver repositorio
          </a>
        </div>
      </section>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>
