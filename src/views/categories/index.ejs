<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="bg-body-tertiary min-vh-100 d-flex flex-column">
    <%- include('../partials/navbar') %>
    <main class="container py-5 flex-grow-1">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
          <h1 class="h2 mb-1">Categorías</h1>
          <p class="text-body-secondary mb-0">Clasifica ingresos y gastos del espacio activo.</p>
        </div>
        <% if (householdPermissions.includes('categories:manage')) { %>
          <a class="btn btn-primary" href="/categories/new">Nueva categoría</a>
        <% } %>
      </div>

      <div class="table-responsive bg-white rounded-4 shadow-sm">
        <table class="table align-middle mb-0">
          <thead><tr><th>Nombre</th><th>Tipo</th><th>Uso</th><th>Estado</th><th class="text-end">Acciones</th></tr></thead>
          <tbody>
            <% categories.forEach((category) => { %>
              <tr>
                <td><strong><%= category.name %></strong><% if (category.isDefault) { %> <span class="badge text-bg-light">Predeterminada</span><% } %></td>
                <td><%= category.categoryTypeLabel %></td>
                <td><%= category.transactionCount %> movimientos / <%= category.budgetCount %> presupuestos</td>
                <td><span class="badge <%= category.active ? 'text-bg-success' : 'text-bg-secondary' %>"><%= category.active ? 'Activa' : 'Inactiva' %></span></td>
                <td class="text-end">
                  <% if (householdPermissions.includes('categories:manage')) { %>
                    <div class="d-inline-flex gap-2">
                      <a class="btn btn-outline-primary btn-sm" href="/categories/<%= category.id %>/edit">Editar</a>
                      <% if (!category.isDefault) { %>
                        <form method="post" action="/categories/<%= category.id %>/status">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <input type="hidden" name="active" value="<%= category.active ? 'false' : 'true' %>" />
                          <button class="btn btn-outline-secondary btn-sm" type="submit"><%= category.active ? 'Desactivar' : 'Activar' %></button>
                        </form>
                      <% } %>
                    </div>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% if (categories.length === 0) { %><div class="alert alert-info mt-3">Este espacio todavía no tiene categorías.</div><% } %>
    </main>
    <%- include('../partials/footer') %>
  </body>
</html>
