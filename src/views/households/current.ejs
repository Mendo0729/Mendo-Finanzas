<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-app-body">
    <div class="mf-workspace-shell">
      <%- include('../partials/app-sidebar', { activeSection: 'household' }) %>
      <button
        class="mf-sidebar-backdrop"
        type="button"
        data-sidebar-close
        aria-label="Cerrar menú"
      ></button>

      <main class="mf-workspace-main">
        <%- include('../partials/app-header', {
          headerEyebrow: 'Contexto financiero',
          headerTitle: household.name,
          primaryAction: householdPermissions.includes('household:update')
            ? { href: `/households/${household.id}/edit`, label: 'Editar espacio' }
            : null,
        }) %>

        <div class="mf-workspace-content">
          <section class="mf-form-shell">
            <article class="mf-page-card mf-household-summary">
              <span class="mf-badge mf-badge--success">Espacio activo</span>
              <h2><%= household.name %></h2>
              <p>Este contexto se aplicará a todas las consultas financieras protegidas.</p>

              <dl class="mf-household-details">
                <dt>Moneda</dt>
                <dd><%= household.currency %></dd>
                <dt>Rol</dt>
                <dd><span class="mf-badge"><%= role.label %></span></dd>
                <dt>Miembro desde</dt>
                <dd><%= joinedAt.toLocaleDateString('es-PA') %></dd>
              </dl>

              <div class="mf-form-actions">
                <a class="mf-button mf-button--primary" href="/households/select">
                  Cambiar espacio
                </a>
                <% if (householdPermissions.includes('household:update')) { %>
                  <a
                    class="mf-button mf-button--ghost"
                    href="/households/<%= household.id %>/edit"
                  >
                    Editar espacio
                  </a>
                <% } %>
                <a class="mf-button mf-button--ghost" href="/">Volver al dashboard</a>
              </div>
            </article>
          </section>
        </div>
      </main>
    </div>
  </body>
</html>
