<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-app-body">
    <div class="mf-workspace-shell">
      <%- include('../partials/app-sidebar', { activeSection: 'household' }) %>
      <button
        class="mf-sidebar-backdrop"
        type="button"
        data-sidebar-close
        aria-label="Cerrar menú"
      ></button>

      <main class="mf-workspace-main">
        <%- include('../partials/app-header', {
          headerEyebrow: 'Espacio financiero',
          headerTitle: household ? 'Editar espacio' : 'Crear espacio',
          primaryAction: null,
        }) %>

        <div class="mf-workspace-content">
          <div class="mf-form-shell">
            <section class="mf-form-panel">
              <div class="mf-form-panel__header">
                <span class="mf-page-kicker">Contexto principal</span>
                <h2><%= household ? 'Editar espacio' : 'Crear espacio' %></h2>
                <p>
                  El nombre y la moneda se utilizarán como referencia principal para todas las
                  operaciones financieras del espacio.
                </p>
              </div>

              <form method="post" action="<%= action %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

                <div class="mf-form-grid">
                  <div class="mf-form-field">
                    <label for="name">Nombre</label>
                    <input
                      class="mf-input"
                      id="name"
                      name="name"
                      type="text"
                      maxlength="100"
                      value="<%= values.name %>"
                      required
                      autofocus
                    />
                    <p class="mf-field-help">Ejemplo: Finanzas personales, Familia o Negocio.</p>
                  </div>

                  <div class="mf-form-field">
                    <label for="currency">Moneda principal</label>
                    <select class="mf-select" id="currency" name="currency" required>
                      <% currencies.forEach((currency) => { %>
                        <option
                          value="<%= currency.value %>"
                          <%= values.currency === currency.value ? 'selected' : '' %>
                        >
                          <%= currency.label %>
                        </option>
                      <% }) %>
                    </select>
                    <p class="mf-field-help">
                      Cambiar la moneda no convierte automáticamente importes existentes.
                    </p>
                  </div>
                </div>

                <% if (!household) { %>
                  <div class="mf-inline-note mt-4">
                    Se crearán categorías iniciales y quedarás asignado como propietario del
                    espacio.
                  </div>
                <% } %>

                <div class="mf-form-actions">
                  <button class="mf-button mf-button--primary" type="submit">
                    <%= household ? 'Guardar cambios' : 'Crear espacio' %>
                  </button>
                  <a
                    class="mf-button mf-button--ghost"
                    href="<%= household ? '/households/current' : '/households/select' %>"
                  >
                    Cancelar
                  </a>
                </div>
              </form>
            </section>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
