<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-app-body">
    <div class="mf-workspace-shell">
      <%- include('../partials/app-sidebar', { activeSection: 'transactions' }) %>
      <button
        class="mf-sidebar-backdrop"
        type="button"
        data-sidebar-close
        aria-label="Cerrar menú"
      ></button>

      <main class="mf-workspace-main">
        <%- include('../partials/app-header', {
          headerEyebrow: 'Finanzas',
          headerTitle: 'Movimientos',
          primaryAction: householdPermissions.includes('transactions:manage')
            ? { href: '/transactions/new', label: 'Nuevo movimiento' }
            : null,
        }) %>

        <div class="mf-workspace-content">
          <div class="mf-page-intro">
            <div>
              <span class="mf-page-kicker">Espacio financiero</span>
              <h2>Ingresos y gastos</h2>
              <p>Busca, filtra y ordena los movimientos registrados en el espacio activo.</p>
            </div>
          </div>

          <section class="mf-form-panel mb-4" aria-labelledby="transaction-filters-title">
            <div class="mf-form-panel__header">
              <span class="mf-page-kicker">Consulta avanzada</span>
              <h2 id="transaction-filters-title">Filtros de movimientos</h2>
              <p>Combina uno o varios criterios. Los filtros se conservan al cambiar de página.</p>
            </div>

            <form method="get" action="/transactions">
              <div class="mf-form-grid">
                <div class="mf-form-field mf-form-field--8">
                  <label for="search">Descripción</label>
                  <input
                    class="mf-input"
                    id="search"
                    name="search"
                    maxlength="100"
                    placeholder="Ej. supermercado"
                    value="<%= filters.search %>"
                  />
                </div>

                <div class="mf-form-field mf-form-field--4">
                  <label for="transactionType">Tipo</label>
                  <select class="mf-select" id="transactionType" name="transactionType">
                    <option value="">Todos</option>
                    <% transactionTypes.forEach((type) => { %>
                      <option
                        value="<%= type.value %>"
                        <%= Number(filters.transactionType) === type.value ? 'selected' : '' %>
                      >
                        <%= type.label %>
                      </option>
                    <% }) %>
                  </select>
                </div>

                <div class="mf-form-field mf-form-field--6">
                  <label for="fromDate">Desde</label>
                  <input
                    class="mf-input"
                    id="fromDate"
                    name="fromDate"
                    type="date"
                    value="<%= filters.fromDate %>"
                  />
                </div>

                <div class="mf-form-field mf-form-field--6">
                  <label for="toDate">Hasta</label>
                  <input
                    class="mf-input"
                    id="toDate"
                    name="toDate"
                    type="date"
                    value="<%= filters.toDate %>"
                  />
                </div>

                <div class="mf-form-field mf-form-field--6">
                  <label for="accountId">Cuenta</label>
                  <select class="mf-select" id="accountId" name="accountId">
                    <option value="">Todas las cuentas</option>
                    <% accounts.forEach((account) => { %>
                      <option
                        value="<%= account.id %>"
                        <%= filters.accountId === account.id ? 'selected' : '' %>
                      >
                        <%= account.name %> · <%= account.currency %>
                      </option>
                    <% }) %>
                  </select>
                </div>

                <div class="mf-form-field mf-form-field--6">
                  <label for="categoryId">Categoría</label>
                  <select class="mf-select" id="categoryId" name="categoryId">
                    <option value="">Todas las categorías</option>
                    <% categories.forEach((category) => { %>
                      <option
                        value="<%= category.id %>"
                        <%= filters.categoryId === category.id ? 'selected' : '' %>
                      >
                        <%= category.categoryType === 1 ? 'Ingreso' : 'Gasto' %> · <%=
                        category.name %>
                      </option>
                    <% }) %>
                  </select>
                </div>

                <div class="mf-form-field mf-form-field--4">
                  <label for="minAmount">Monto mínimo</label>
                  <input
                    class="mf-input"
                    id="minAmount"
                    name="minAmount"
                    inputmode="decimal"
                    placeholder="0.00"
                    value="<%= filters.minAmount %>"
                  />
                </div>

                <div class="mf-form-field mf-form-field--4">
                  <label for="maxAmount">Monto máximo</label>
                  <input
                    class="mf-input"
                    id="maxAmount"
                    name="maxAmount"
                    inputmode="decimal"
                    placeholder="0.00"
                    value="<%= filters.maxAmount %>"
                  />
                </div>

                <div class="mf-form-field mf-form-field--4">
                  <label for="sort">Ordenar por</label>
                  <select class="mf-select" id="sort" name="sort">
                    <% sortOptions.forEach((option) => { %>
                      <option
                        value="<%= option.value %>"
                        <%= filters.sort === option.value ? 'selected' : '' %>
                      >
                        <%= option.label %>
                      </option>
                    <% }) %>
                  </select>
                </div>
              </div>

              <div class="mf-form-actions">
                <button class="mf-button mf-button--primary" type="submit">Aplicar filtros</button>
                <a class="mf-button mf-button--ghost" href="/transactions">Limpiar</a>
              </div>
            </form>
          </section>

          <div class="mf-page-intro">
            <div>
              <span class="mf-page-kicker">Resultados</span>
              <h2><%= pagination.total %> movimiento<%= pagination.total === 1 ? '' : 's' %></h2>
              <p>
                Página <%= pagination.currentPage %> de <%= pagination.totalPages %>. Se muestran hasta
                <%= pagination.pageSize %> resultados por página.
              </p>
            </div>
          </div>

          <% if (transactions.length > 0) { %>
            <section class="mf-account-grid" aria-label="Listado de movimientos">
              <% transactions.forEach((transaction) => { %>
                <article class="mf-account-card">
                  <div class="mf-account-card__head">
                    <div>
                      <h3><%= transaction.description %></h3>
                      <p><%= transaction.transactionDateLabel %></p>
                    </div>
                    <span
                      class="mf-badge <%= transaction.transactionType === 1 ? 'mf-badge--success' : 'mf-badge--danger' %>"
                    >
                      <%= transaction.transactionTypeLabel %>
                    </span>
                  </div>

                  <dl class="mf-account-card__meta">
                    <dt>Monto</dt>
                    <dd
                      data-currency-value="<%= transaction.transactionType === 1 ? transaction.amount : `-${transaction.amount}` %>"
                      data-currency="<%= transaction.account.currency %>"
                    ></dd>
                    <dt>Cuenta</dt>
                    <dd><%= transaction.account.name %></dd>
                    <dt>Categoría</dt>
                    <dd><%= transaction.category?.name ?? 'Sin categoría' %></dd>
                  </dl>

                  <% if (transaction.notes) { %>
                    <p class="mb-0"><%= transaction.notes %></p>
                  <% } %>

                  <div class="mf-account-card__actions">
                    <a class="mf-small-button" href="/transactions/<%= transaction.id %>">
                      Ver detalle
                    </a>
                    <% if (householdPermissions.includes('transactions:manage')) { %>
                      <a
                        class="mf-small-button mf-small-button--primary"
                        href="/transactions/<%= transaction.id %>/edit"
                      >
                        Editar
                      </a>
                    <% } %>
                  </div>
                </article>
              <% }) %>
            </section>
          <% } else { %>
            <section class="mf-empty-state">
              <h2 class="h5">
                <%= hasActiveFilters ? 'No hay movimientos que coincidan' : 'Aún no hay movimientos' %>
              </h2>
              <p class="mb-0">
                <%= hasActiveFilters
                  ? 'Ajusta o limpia los filtros para ampliar la búsqueda.'
                  : 'Registra un ingreso o gasto para comenzar a construir tu historial.' %>
              </p>
            </section>
          <% } %>

          <% if (pagination.totalPages > 1) { %>
            <nav class="mf-form-actions" aria-label="Paginación de movimientos">
              <% if (pagination.previousUrl) { %>
                <a class="mf-button mf-button--ghost" href="<%= pagination.previousUrl %>"
                  >Página anterior</a
                >
              <% } %>
              <span>Página <%= pagination.currentPage %> de <%= pagination.totalPages %></span>
              <% if (pagination.nextUrl) { %>
                <a class="mf-button mf-button--primary" href="<%= pagination.nextUrl %>"
                  >Página siguiente</a
                >
              <% } %>
            </nav>
          <% } %>
        </div>
      </main>
    </div>
  </body>
</html>
