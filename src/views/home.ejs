<!doctype html>
<html lang="es">
  <%- include('partials/head') %>
  <% if (currentUser && currentHousehold && dashboard) { %>
    <body class="dashboard-body">
      <div class="dashboard-shell">
        <%- include('partials/app-sidebar', { activeSection: 'dashboard' }) %>
        <button
          class="mf-sidebar-backdrop"
          type="button"
          data-sidebar-close
          aria-label="Cerrar menú"
        ></button>

        <main class="mf-dashboard-main">
          <%- include('partials/app-header', {
            headerEyebrow: 'Panel financiero',
            headerTitle: `Hola, ${currentUser.name.split(' ')[0]}`,
            primaryAction: null,
          }) %>

          <div class="mf-dashboard-content">
            <section class="mf-metrics-grid" aria-label="Resumen financiero">
              <article class="mf-metric-card mf-metric-card--balance">
                <div class="mf-metric-card__header">
                  <span class="mf-metric-icon" aria-hidden="true">◫</span>
                  <span class="mf-chip">Balance total</span>
                </div>
                <strong
                  class="mf-metric-value"
                  data-currency-value="<%= dashboard.balance %>"
                  data-currency="<%= dashboard.currency %>"
                ></strong>
                <p>Saldo consolidado de tus cuentas activas</p>
              </article>

              <article class="mf-metric-card">
                <div class="mf-metric-card__header">
                  <span class="mf-metric-icon mf-metric-icon--income" aria-hidden="true">↗</span>
                  <span class="mf-chip">Ingresos del mes</span>
                </div>
                <strong
                  class="mf-metric-value"
                  data-currency-value="<%= dashboard.income %>"
                  data-currency="<%= dashboard.currency %>"
                ></strong>
                <p
                  class="mf-trend <%= dashboard.incomeChange !== null && dashboard.incomeChange >= 0 ? 'is-positive' : 'is-negative' %>"
                >
                  <% if (dashboard.incomeChange === null) { %>
                    Sin comparación disponible
                  <% } else { %>
                    <%= dashboard.incomeChange >= 0 ? '↑' : '↓' %>
                    <%= Math.abs(dashboard.incomeChange) %>% vs. mes anterior
                  <% } %>
                </p>
              </article>

              <article class="mf-metric-card">
                <div class="mf-metric-card__header">
                  <span class="mf-metric-icon mf-metric-icon--expense" aria-hidden="true">↘</span>
                  <span class="mf-chip">Gastos del mes</span>
                </div>
                <strong
                  class="mf-metric-value"
                  data-currency-value="<%= dashboard.expense %>"
                  data-currency="<%= dashboard.currency %>"
                ></strong>
                <p
                  class="mf-trend <%= dashboard.expenseChange !== null && dashboard.expenseChange <= 0 ? 'is-positive' : 'is-negative' %>"
                >
                  <% if (dashboard.expenseChange === null) { %>
                    Sin comparación disponible
                  <% } else { %>
                    <%= dashboard.expenseChange >= 0 ? '↑' : '↓' %>
                    <%= Math.abs(dashboard.expenseChange) %>% vs. mes anterior
                  <% } %>
                </p>
              </article>
            </section>

            <% if (dashboard.budgetAlert) { %>
              <section class="mf-budget-alert" aria-label="Alerta de presupuesto">
                <span class="mf-budget-alert__icon" aria-hidden="true">!</span>
                <div>
                  <strong>
                    Presupuesto de <%= dashboard.budgetAlert.name %> al
                    <%= dashboard.budgetAlert.percentage %>%
                  </strong>
                  <p>Has utilizado una parte importante del presupuesto mensual asignado.</p>
                </div>
                <div class="mf-budget-alert__amount">
                  <strong
                    data-currency-value="<%= dashboard.budgetAlert.spent %>"
                    data-currency="<%= dashboard.currency %>"
                  ></strong>
                  <span>
                    de
                    <span
                      data-currency-value="<%= dashboard.budgetAlert.limit %>"
                      data-currency="<%= dashboard.currency %>"
                    ></span>
                  </span>
                </div>
              </section>
            <% } %>

            <section class="mf-analytics-grid">
              <article class="mf-panel mf-panel--wide">
                <div class="mf-panel__header mf-chart-panel-header">
                  <div>
                    <p class="mf-eyebrow" data-chart-period-label aria-live="polite">
                      Últimos 6 meses
                    </p>
                    <h2>Ingresos y gastos</h2>
                  </div>
                  <div class="mf-chart-header-actions">
                    <div class="mf-chart-period" role="group" aria-label="Periodo de la gráfica">
                      <button type="button" data-chart-period="3" aria-pressed="false">
                        3 meses
                      </button>
                      <button
                        class="is-active"
                        type="button"
                        data-chart-period="6"
                        aria-pressed="true"
                      >
                        6 meses
                      </button>
                      <button type="button" data-chart-period="12" aria-pressed="false">
                        12 meses
                      </button>
                    </div>
                    <div class="mf-chart-legend" aria-label="Leyenda">
                      <span><i class="is-income"></i> Ingresos</span>
                      <span><i class="is-expense"></i> Gastos</span>
                    </div>
                  </div>
                </div>
                <div class="mf-bar-chart-scroll">
                  <div
                    class="mf-bar-chart"
                    data-monthly-series='<%- JSON.stringify(dashboard.monthlySeries) %>'
                    data-currency="<%= dashboard.currency %>"
                    data-default-period="6"
                    aria-label="Gráfica de ingresos y gastos"
                  ></div>
                </div>
              </article>

              <article class="mf-panel">
                <div class="mf-panel__header">
                  <div>
                    <p class="mf-eyebrow">Mes actual</p>
                    <h2>Gastos por categoría</h2>
                  </div>
                </div>
                <% if (dashboard.categoryExpenses.length) { %>
                  <div
                    class="mf-category-chart"
                    data-category-expenses='<%- JSON.stringify(dashboard.categoryExpenses) %>'
                  >
                    <div class="mf-donut" aria-hidden="true"></div>
                    <ul class="mf-category-list"></ul>
                  </div>
                <% } else { %>
                  <div class="mf-empty-state">Aún no hay gastos categorizados este mes.</div>
                <% } %>
              </article>
            </section>

            <section class="mf-bottom-grid">
              <article class="mf-panel mf-panel--transactions">
                <div class="mf-panel__header">
                  <div>
                    <p class="mf-eyebrow">Actividad reciente</p>
                    <h2>Últimas transacciones</h2>
                  </div>
                </div>
                <% if (dashboard.recentTransactions.length) { %>
                  <div class="mf-transactions-table-wrap">
                    <table class="mf-transactions-table">
                      <thead>
                        <tr>
                          <th>Descripción</th>
                          <th>Categoría</th>
                          <th>Cuenta</th>
                          <th>Fecha</th>
                          <th>Monto</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% dashboard.recentTransactions.forEach((transaction) => { %>
                          <tr>
                            <td data-label="Descripción">
                              <strong><%= transaction.description %></strong>
                            </td>
                            <td data-label="Categoría">
                              <%= transaction.category?.name ?? 'Sin categoría' %>
                            </td>
                            <td data-label="Cuenta"><%= transaction.account.name %></td>
                            <td data-label="Fecha">
                              <%= new Intl.DateTimeFormat('es-PA', {
                                day: '2-digit',
                                month: 'short',
                                timeZone: 'UTC',
                              }).format(transaction.transactionDate) %>
                            </td>
                            <td
                              data-label="Monto"
                              class="<%= transaction.transactionType === 1 || transaction.transactionType === 4 ? 'is-income' : 'is-expense' %>"
                            >
                              <%= transaction.transactionType === 1 || transaction.transactionType === 4 ? '+' : '-' %><span
                                data-currency-value="<%= transaction.amount %>"
                                data-currency="<%= dashboard.currency %>"
                              ></span>
                            </td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                <% } else { %>
                  <div class="mf-empty-state">No hay transacciones registradas todavía.</div>
                <% } %>
              </article>

              <article class="mf-panel">
                <div class="mf-panel__header">
                  <div>
                    <p class="mf-eyebrow">Control mensual</p>
                    <h2>Presupuestos</h2>
                  </div>
                </div>
                <% if (dashboard.budgetProgress.length) { %>
                  <div class="mf-budget-list">
                    <% dashboard.budgetProgress.slice(0, 5).forEach((budget) => { %>
                      <div class="mf-budget-item">
                        <div class="mf-budget-item__header">
                          <strong><%= budget.name %></strong>
                          <span><%= budget.percentage %>%</span>
                        </div>
                        <div
                          class="mf-progress"
                          role="progressbar"
                          aria-valuenow="<%= Math.min(budget.percentage, 100) %>"
                          aria-valuemin="0"
                          aria-valuemax="100"
                        >
                          <span style="width: <%= Math.min(budget.percentage, 100) %>%"></span>
                        </div>
                        <p>
                          <span
                            data-currency-value="<%= budget.spent %>"
                            data-currency="<%= dashboard.currency %>"
                          ></span>
                          de
                          <span
                            data-currency-value="<%= budget.limit %>"
                            data-currency="<%= dashboard.currency %>"
                          ></span>
                        </p>
                      </div>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="mf-empty-state">
                    No hay presupuestos configurados para este mes.
                  </div>
                <% } %>
              </article>
            </section>
          </div>
        </main>
      </div>
    </body>
  <% } else if (currentUser) { %>
    <body class="mf-app-body">
      <div class="mf-workspace-shell">
        <%- include('partials/app-sidebar', { activeSection: 'household' }) %>
        <button
          class="mf-sidebar-backdrop"
          type="button"
          data-sidebar-close
          aria-label="Cerrar menú"
        ></button>
        <main class="mf-workspace-main">
          <%- include('partials/app-header', {
            headerEyebrow: 'Contexto financiero',
            headerTitle: `Hola, ${currentUser.name.split(' ')[0]}`,
            primaryAction: { href: '/households/new', label: 'Crear espacio' },
          }) %>
          <div class="mf-workspace-content">
            <div class="mf-form-shell">
              <section class="mf-form-panel">
                <div class="mf-form-panel__header">
                  <span class="mf-page-kicker">Espacio pendiente</span>
                  <h2>Selecciona tu contexto financiero</h2>
                  <p>
                    Elige el espacio que deseas utilizar antes de consultar o modificar datos.
                  </p>
                </div>
                <div class="mf-form-actions">
                  <a class="mf-button mf-button--primary" href="/households/select">
                    Seleccionar espacio
                  </a>
                  <a class="mf-button mf-button--ghost" href="/security">Seguridad</a>
                </div>
              </section>
            </div>
          </div>
        </main>
      </div>
    </body>
  <% } else { %>
    <body class="mf-auth-body">
      <%- include('partials/navbar') %>
      <main class="flex-grow-1">
        <section class="mf-public-hero">
          <div class="mf-public-hero__content">
            <span class="mf-auth-card__badge">SharedWallet</span>
            <h1>Organiza tus finanzas con claridad.</h1>
            <p>
              Administra cuentas, categorías y presupuestos desde una plataforma segura y fácil
              de entender.
            </p>
            <div class="mf-public-hero__actions">
              <a class="mf-button mf-button--primary" href="/auth/register">Crear cuenta</a>
              <a class="mf-button mf-button--ghost" href="/auth/login">Iniciar sesión</a>
            </div>
          </div>
        </section>
      </main>
      <%- include('partials/footer') %>
    </body>
  <% } %>
</html>
