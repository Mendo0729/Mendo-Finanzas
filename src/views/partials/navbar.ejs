<nav class="navbar navbar-expand-lg bg-white border-bottom" aria-label="Navegación principal">
  <div class="container">
    <a class="navbar-brand fw-semibold" href="/">Mendo Finanzas</a>

    <div class="ms-auto d-flex align-items-center gap-2">
      <% if (currentUser) { %>
        <span class="small text-body-secondary d-none d-sm-inline">
          Sesión activa como <strong><%= currentUser.name %></strong>
        </span>
        <form method="post" action="/auth/logout" class="m-0">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="btn btn-outline-danger btn-sm" type="submit">Cerrar sesión</button>
        </form>
      <% } else { %>
        <a class="btn btn-outline-primary btn-sm" href="/auth/login">Iniciar sesión</a>
        <a class="btn btn-primary btn-sm" href="/auth/register">Crear cuenta</a>
      <% } %>
    </div>
  </div>
</nav>
