<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-app-body">
    <div class="mf-workspace-shell">
      <%- include('../partials/app-sidebar', { activeSection: 'security' }) %>
      <button
        class="mf-sidebar-backdrop"
        type="button"
        data-sidebar-close
        aria-label="Cerrar menú"
      ></button>

      <main class="mf-workspace-main">
        <%- include('../partials/app-header', {
          headerEyebrow: 'Seguridad',
          headerTitle: 'Configurar MFA',
          primaryAction: null,
        }) %>

        <div class="mf-workspace-content">
          <div class="mf-form-shell">
            <section class="mf-form-panel">
              <div class="mf-form-panel__header">
                <span class="mf-page-kicker">Autenticación en dos pasos</span>
                <h2>Configurar Authenticator</h2>
                <p>
                  Escanea el código QR con Google Authenticator, Microsoft Authenticator u otra
                  aplicación compatible.
                </p>
              </div>

              <div class="mf-setup-grid">
                <div class="mf-qr-panel" aria-label="Código QR para configurar MFA">
                  <%- setup.qrSvg %>
                </div>

                <div>
                  <ol class="mf-setup-steps">
                    <li>Abre tu aplicación de autenticación.</li>
                    <li>Selecciona la opción para escanear un código QR.</li>
                    <li>Escanea el código y confirma con el código temporal de seis dígitos.</li>
                  </ol>

                  <details>
                    <summary class="text-success fw-semibold">No puedo escanear el QR</summary>
                    <div class="mf-secret-panel">
                      <p class="mf-field-help mb-1">Clave de configuración manual</p>
                      <code class="text-break"><%= setup.secret %></code>
                    </div>
                  </details>
                </div>
              </div>

              <form method="post" action="/security/mfa/setup/confirm" class="mt-4">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <div class="mf-form-field">
                  <label for="token">Código de 6 dígitos</label>
                  <input
                    class="mf-input text-center font-monospace <%= fieldError ? 'is-invalid' : '' %>"
                    id="token"
                    name="token"
                    type="text"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    pattern="[0-9]{6}"
                    maxlength="6"
                    required
                    autofocus
                  />
                  <% if (fieldError) { %>
                    <p class="text-danger small mb-0"><%= fieldError %></p>
                  <% } %>
                </div>

                <div class="mf-form-actions">
                  <button class="mf-button mf-button--primary" type="submit">
                    Verificar y habilitar
                  </button>
                  <a class="mf-button mf-button--ghost" href="/security">Cancelar</a>
                </div>
              </form>
            </section>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
