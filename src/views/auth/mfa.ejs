<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-auth-body">
    <%- include('../partials/navbar') %>

    <main class="mf-auth-main">
      <div class="mf-auth-layout">
        <section class="mf-auth-intro" aria-labelledby="mfaIntroTitle">
          <span class="mf-auth-intro__eyebrow">Protección adicional</span>
          <h1 id="mfaIntroTitle">Confirma que realmente eres tú.</h1>
          <p>
            La verificación en dos pasos protege tus espacios financieros incluso si alguien
            obtiene tu contraseña.
          </p>
          <ul class="mf-auth-features">
            <li>Código temporal de seis dígitos</li>
            <li>Compatible con aplicaciones de autenticación</li>
            <li>Códigos de recuperación de un solo uso</li>
          </ul>
        </section>

        <section class="mf-auth-card" aria-labelledby="mfaTitle">
          <div class="mf-auth-card__body">
            <span class="mf-auth-card__badge">Segundo factor</span>
            <h1 id="mfaTitle">Verificación en dos pasos</h1>
            <p class="mf-auth-card__subtitle">
              Introduce el código generado por tu aplicación de autenticación.
            </p>

            <% if (formError) { %>
              <div class="mf-auth-alert" role="alert"><%= formError %></div>
            <% } %>

            <form class="mf-auth-form" method="post" action="/auth/mfa">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div class="mf-auth-field">
                <label for="token">Código de autenticación</label>
                <input
                  class="mf-auth-input mf-mfa-code"
                  id="token"
                  name="token"
                  type="text"
                  inputmode="numeric"
                  autocomplete="one-time-code"
                  pattern="[0-9]{6}"
                  maxlength="6"
                  aria-describedby="tokenHelp"
                  required
                  autofocus
                />
                <p class="mf-auth-help" id="tokenHelp">Escribe los seis dígitos sin espacios.</p>
              </div>
              <button class="mf-auth-submit" type="submit">Verificar e iniciar sesión</button>
            </form>

            <div class="mf-auth-divider">o continúa con</div>

            <details class="mf-recovery-panel">
              <summary>Usar un código de recuperación</summary>
              <div class="mf-recovery-panel__body">
                <form class="mf-auth-form" method="post" action="/auth/mfa/recovery">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <div class="mf-auth-field">
                    <label for="recoveryCode">Código de recuperación</label>
                    <input
                      class="mf-auth-input font-monospace text-uppercase"
                      id="recoveryCode"
                      name="recoveryCode"
                      type="text"
                      autocomplete="off"
                      maxlength="20"
                      required
                    />
                    <p class="mf-auth-help">Cada código puede utilizarse una sola vez.</p>
                  </div>
                  <button class="mf-button mf-button--ghost w-100" type="submit">
                    Iniciar sesión con código de recuperación
                  </button>
                </form>
              </div>
            </details>

            <p class="mf-auth-switch">
              <a href="/auth/login">Cancelar y volver al inicio de sesión</a>
            </p>
          </div>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
