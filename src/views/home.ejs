<!doctype html>
<html lang="es">
  <%- include('partials/head') %>
  <body class="bg-body-tertiary min-vh-100 d-flex flex-column">
    <%- include('partials/navbar') %>

    <main class="container py-5 flex-grow-1">
      <section class="rounded-4 bg-white p-4 p-md-5 shadow-sm">
        <% if (currentUser) { %>
          <span class="badge text-bg-success mb-3">Sesión autenticada</span>
          <h1 class="display-5 fw-bold">Hola, <%= currentUser.name %></h1>
          <p class="lead">
            Tu cuenta está lista. Los espacios financieros se incorporarán en la siguiente fase.
          </p>
        <% } else { %>
          <span class="badge text-bg-primary mb-3">Mendo Finanzas</span>
          <h1 class="display-5 fw-bold">Organiza tus finanzas con claridad</h1>
          <p class="lead">Crea una cuenta o inicia sesión para comenzar.</p>
          <div class="d-flex flex-wrap gap-2 mb-4">
            <a class="btn btn-primary" href="/auth/register">Crear cuenta</a>
            <a class="btn btn-outline-primary" href="/auth/login">Iniciar sesión</a>
          </div>
        <% } %>

        <dl class="row mb-4">
          <dt class="col-sm-3">Aplicación</dt>
          <dd class="col-sm-9 text-success">Activa</dd>

          <dt class="col-sm-3">Base de datos</dt>
          <dd class="col-sm-9">
            <span
              class="badge <%= databaseStatus === 'up' ? 'text-bg-success' : 'text-bg-danger' %>"
            >
              <%= databaseStatus === 'up' ? 'Disponible' : 'No disponible' %>
            </span>
          </dd>

          <dt class="col-sm-3">Entorno</dt>
          <dd class="col-sm-9"><code><%= environment %></code></dd>
        </dl>

        <a class="btn btn-outline-secondary" href="/health">Consultar healthcheck</a>
      </section>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>
