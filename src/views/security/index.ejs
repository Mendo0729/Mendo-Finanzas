<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="bg-body-tertiary min-vh-100 d-flex flex-column">
    <%- include('../partials/navbar') %>

    <main class="container py-5 flex-grow-1">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <section class="rounded-4 bg-white p-4 p-md-5 shadow-sm">
            <span class="badge text-bg-primary mb-3">Cuenta</span>
            <h1 class="h2">Seguridad</h1>
            <p class="text-body-secondary mb-4">
              Protege el acceso a tu cuenta con una aplicación de autenticación.
            </p>

            <% if (successMessage) { %>
              <div class="alert alert-success"><%= successMessage %></div>
            <% } %>
            <% if (formError) { %>
              <div class="alert alert-danger"><%= formError %></div>
            <% } %>

            <div class="border rounded-3 p-4 mb-4 d-flex flex-column flex-md-row justify-content-between gap-3">
              <div>
                <h2 class="h5 mb-2">Autenticación en dos pasos</h2>
                <% if (mfa.enabled) { %>
                  <span class="badge text-bg-success">Habilitada</span>
                  <p class="small text-body-secondary mt-2 mb-1">
                    Activada el <%= mfa.enabledAt.toLocaleDateString('es-PA') %>.
                  </p>
                  <p class="small text-body-secondary mb-0">
                    Códigos de recuperación disponibles: <strong><%= mfa.unusedRecoveryCodes %></strong>
                  </p>
                <% } else { %>
                  <span class="badge text-bg-secondary">Desactivada</span>
                  <p class="small text-body-secondary mt-2 mb-0">
                    Compatible con Google Authenticator y Microsoft Authenticator.
                  </p>
                <% } %>
              </div>

              <% if (!mfa.enabled) { %>
                <div class="align-self-md-center">
                  <a class="btn btn-primary" href="/security/mfa/setup">Configurar Authenticator</a>
                </div>
              <% } %>
            </div>

            <% if (mfa.enabled) { %>
              <div class="row g-4">
                <div class="col-md-6">
                  <div class="border rounded-3 p-4 h-100">
                    <h2 class="h5">Regenerar códigos de recuperación</h2>
                    <p class="small text-body-secondary">
                      Los códigos anteriores dejarán de funcionar inmediatamente.
                    </p>
                    <form method="post" action="/security/mfa/recovery-codes/regenerate" class="vstack gap-3">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <div>
                        <label class="form-label" for="regenerate-password">Contraseña actual</label>
                        <input
                          class="form-control"
                          id="regenerate-password"
                          name="password"
                          type="password"
                          autocomplete="current-password"
                          maxlength="128"
                          required
                        />
                      </div>
                      <button class="btn btn-outline-primary" type="submit">Generar nuevos códigos</button>
                    </form>
                  </div>
                </div>

                <div class="col-md-6">
                  <div class="border border-danger rounded-3 p-4 h-100">
                    <h2 class="h5 text-danger">Desactivar MFA</h2>
                    <p class="small text-body-secondary">
                      Tu cuenta volverá a depender solamente del correo y la contraseña.
                    </p>
                    <form method="post" action="/security/mfa/disable" class="vstack gap-3">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <div>
                        <label class="form-label" for="disable-password">Contraseña actual</label>
                        <input
                          class="form-control"
                          id="disable-password"
                          name="password"
                          type="password"
                          autocomplete="current-password"
                          maxlength="128"
                          required
                        />
                      </div>
                      <button class="btn btn-outline-danger" type="submit">Desactivar autenticación en dos pasos</button>
                    </form>
                  </div>
                </div>
              </div>
            <% } %>
          </section>
        </div>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
