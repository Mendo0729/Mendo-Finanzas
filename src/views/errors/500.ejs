<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %> | Mendo Finanzas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" />
  </head>
  <body class="bg-body-tertiary">
    <main class="container py-5 text-center">
      <p class="display-1 fw-bold text-danger">500</p>
      <h1 class="h2">Ocurrió un error interno</h1>
      <p class="text-body-secondary">La solicitud no pudo procesarse. Intenta nuevamente más tarde.</p>
      <% if (errorMessage) { %>
        <div class="alert alert-warning text-start mx-auto" style="max-width: 48rem" role="alert">
          <strong>Detalle de desarrollo:</strong> <%= errorMessage %>
        </div>
      <% } %>
      <a class="btn btn-primary" href="/">Volver al inicio</a>
    </main>
  </body>
</html>
