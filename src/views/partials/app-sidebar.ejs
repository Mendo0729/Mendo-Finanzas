<aside class="mf-sidebar" id="appSidebar" aria-label="Navegación principal del espacio">
  <a class="mf-sidebar__brand text-decoration-none" href="/" aria-label="Ir al dashboard">
    <span class="mf-brand-mark" aria-hidden="true">SW</span>
    <span>
      <strong>SharedWallet</strong>
      <span><%= currentHousehold ? currentHousehold.name : 'Cuenta personal' %></span>
    </span>
  </a>

  <nav class="mf-sidebar__nav">
    <a
      class="mf-nav-link <%= activeSection === 'dashboard' ? 'is-active' : '' %>"
      href="/"
      <%- activeSection === 'dashboard' ? 'aria-current="page"' : '' %>
    >
      <span aria-hidden="true">⌂</span> Dashboard
    </a>

    <span class="mf-nav-label">Administración</span>

    <% if (householdPermissions.includes('accounts:view')) { %>
      <a
        class="mf-nav-link <%= activeSection === 'accounts' ? 'is-active' : '' %>"
        href="/accounts"
        <%- activeSection === 'accounts' ? 'aria-current="page"' : '' %>
      >
        <span aria-hidden="true">▣</span> Cuentas
      </a>
    <% } %>

    <% if (householdPermissions.includes('transactions:view')) { %>
      <a
        class="mf-nav-link <%= activeSection === 'transactions' ? 'is-active' : '' %>"
        href="/transactions"
        <%- activeSection === 'transactions' ? 'aria-current="page"' : '' %>
      >
        <span aria-hidden="true">↕</span> Movimientos
      </a>
    <% } %>

    <% if (householdPermissions.includes('budgets:view')) { %>
      <a
        class="mf-nav-link <%= activeSection === 'budgets' ? 'is-active' : '' %>"
        href="/budgets"
        <%- activeSection === 'budgets' ? 'aria-current="page"' : '' %>
      >
        <span aria-hidden="true">◎</span> Presupuestos
      </a>
    <% } %>

    <% if (householdPermissions.includes('categories:view')) { %>
      <a
        class="mf-nav-link <%= activeSection === 'categories' ? 'is-active' : '' %>"
        href="/categories"
        <%- activeSection === 'categories' ? 'aria-current="page"' : '' %>
      >
        <span aria-hidden="true">◇</span> Categorías
      </a>
    <% } %>

    <a
      class="mf-nav-link <%= activeSection === 'household' ? 'is-active' : '' %>"
      href="<%= currentHousehold ? '/households/current' : '/households/select' %>"
      <%- activeSection === 'household' ? 'aria-current="page"' : '' %>
    >
      <span aria-hidden="true">⌂</span> Espacio financiero
    </a>

    <a
      class="mf-nav-link <%= activeSection === 'security' ? 'is-active' : '' %>"
      href="/security"
      <%- activeSection === 'security' ? 'aria-current="page"' : '' %>
    >
      <span aria-hidden="true">◉</span> Seguridad
    </a>
  </nav>

  <div class="mf-sidebar__profile flex-column align-items-stretch gap-3">
    <div class="d-flex align-items-center gap-2">
      <div class="mf-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></div>
      <div class="mf-profile-copy">
        <strong><%= currentUser.name %></strong>
        <span><%= currentHouseholdRole?.label ?? 'Usuario' %></span>
      </div>
    </div>

    <form method="post" action="/auth/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button class="mf-button mf-button--danger-ghost w-100" type="submit">
        <span aria-hidden="true">↪</span>
        <span>Cerrar sesión</span>
      </button>
    </form>
  </div>
</aside>
