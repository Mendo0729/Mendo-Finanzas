<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-app-body">
    <div class="mf-workspace-shell">
      <%- include('../partials/app-sidebar', { activeSection: 'transactions' }) %>
      <button
        class="mf-sidebar-backdrop"
        type="button"
        data-sidebar-close
        aria-label="Cerrar menú"
      ></button>

      <main class="mf-workspace-main">
        <%- include('../partials/app-header', {
          headerEyebrow: 'Movimientos',
          headerTitle: 'Detalle del movimiento',
          primaryAction: householdPermissions.includes('transactions:manage')
            ? { href: `/transactions/${transaction.id}/edit`, label: 'Editar movimiento' }
            : null,
        }) %>

        <div class="mf-workspace-content">
          <div class="mf-page-intro">
            <div>
              <span class="mf-page-kicker"><%= transaction.transactionTypeLabel %></span>
              <h2><%= transaction.description %></h2>
              <p>Información registrada para este movimiento dentro del espacio activo.</p>
            </div>
          </div>

          <section class="mf-account-grid" aria-label="Detalle del movimiento">
            <article class="mf-account-card">
              <div class="mf-account-card__head">
                <div>
                  <h3>Monto</h3>
                  <p><%= transaction.transactionDateLabel %></p>
                </div>
                <span
                  class="mf-badge <%= transaction.transactionType === 1 ? 'mf-badge--success' : 'mf-badge--danger' %>"
                >
                  <%= transaction.transactionTypeLabel %>
                </span>
              </div>

              <dl class="mf-account-card__meta">
                <dt>Valor</dt>
                <dd
                  data-currency-value="<%= transaction.transactionType === 1 ? transaction.amount : `-${transaction.amount}` %>"
                  data-currency="<%= transaction.account.currency %>"
                ></dd>
                <dt>Cuenta</dt>
                <dd><%= transaction.account.name %></dd>
                <dt>Categoría</dt>
                <dd><%= transaction.category?.name ?? 'Sin categoría' %></dd>
                <dt>Creado por</dt>
                <dd><%= transaction.creator.name %></dd>
                <dt>Registrado</dt>
                <dd><%= transaction.createdAtLabel %></dd>
                <dt>Última actualización</dt>
                <dd><%= transaction.updatedAtLabel %></dd>
              </dl>

              <% if (transaction.notes) { %>
                <p class="mb-0"><strong>Notas:</strong> <%= transaction.notes %></p>
              <% } %>

              <div class="mf-account-card__actions">
                <a class="mf-small-button" href="/transactions">Volver</a>
                <% if (householdPermissions.includes('transactions:manage')) { %>
                  <a
                    class="mf-small-button mf-small-button--primary"
                    href="/transactions/<%= transaction.id %>/edit"
                  >
                    Editar
                  </a>
                  <form method="post" action="/transactions/<%= transaction.id %>/void">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="mf-small-button" type="submit">Anular movimiento</button>
                  </form>
                <% } %>
              </div>
            </article>
          </section>
        </div>
      </main>
    </div>
  </body>
</html>
