<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-app-body">
    <div class="mf-workspace-shell">
      <%- include('../partials/app-sidebar', { activeSection: 'accounts' }) %>
      <button
        class="mf-sidebar-backdrop"
        type="button"
        data-sidebar-close
        aria-label="Cerrar menú"
      ></button>

      <main class="mf-workspace-main">
        <%- include('../partials/app-header', {
          headerEyebrow: 'Administración',
          headerTitle: 'Cuentas',
          primaryAction: householdPermissions.includes('accounts:manage')
            ? { href: '/accounts/new', label: 'Nueva cuenta' }
            : null,
        }) %>

        <div class="mf-workspace-content">
          <div class="mf-page-intro">
            <div>
              <span class="mf-page-kicker">Espacio financiero</span>
              <h2>Tus cuentas</h2>
              <p>Consulta y administra las cuentas asociadas al espacio activo.</p>
            </div>
          </div>

          <% if (accounts.length > 0) { %>
            <section class="mf-account-grid" aria-label="Listado de cuentas">
              <% accounts.forEach((account) => { %>
                <article class="mf-account-card">
                  <div class="mf-account-card__head">
                    <div>
                      <h3><%= account.name %></h3>
                      <p><%= account.accountTypeLabel %></p>
                    </div>
                    <span
                      class="mf-badge <%= account.active ? 'mf-badge--success' : 'mf-badge--danger' %>"
                    >
                      <%= account.active ? 'Activa' : 'Inactiva' %>
                    </span>
                  </div>

                  <dl class="mf-account-card__meta">
                    <dt>Moneda</dt>
                    <dd><%= account.currency %></dd>
                    <dt>Saldo inicial</dt>
                    <dd
                      data-currency-value="<%= account.initialBalance %>"
                      data-currency="<%= account.currency %>"
                    ></dd>
                    <dt>Movimientos</dt>
                    <dd><%= account.transactionCount %></dd>
                  </dl>

                  <% if (householdPermissions.includes('accounts:manage')) { %>
                    <div class="mf-account-card__actions">
                      <a
                        class="mf-small-button mf-small-button--primary"
                        href="/accounts/<%= account.id %>/edit"
                      >
                        Editar
                      </a>
                      <form method="post" action="/accounts/<%= account.id %>/status">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <input
                          type="hidden"
                          name="active"
                          value="<%= account.active ? 'false' : 'true' %>"
                        />
                        <button class="mf-small-button" type="submit">
                          <%= account.active ? 'Desactivar' : 'Activar' %>
                        </button>
                      </form>
                    </div>
                  <% } %>
                </article>
              <% }) %>
            </section>
          <% } else { %>
            <section class="mf-empty-state">
              <h2 class="h5">Aún no hay cuentas</h2>
              <p class="mb-0">Crea la primera cuenta para comenzar a registrar movimientos.</p>
            </section>
          <% } %>
        </div>
      </main>
    </div>
  </body>
</html>
