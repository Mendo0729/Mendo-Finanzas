<!doctype html>
<html lang="es">
  <%- include('../partials/head') %>
  <body class="mf-app-body">
    <div class="mf-workspace-shell">
      <%- include('../partials/app-sidebar', { activeSection: 'security' }) %>
      <button
        class="mf-sidebar-backdrop"
        type="button"
        data-sidebar-close
        aria-label="Cerrar menú"
      ></button>

      <main class="mf-workspace-main">
        <%- include('../partials/app-header', {
          headerEyebrow: 'Seguridad',
          headerTitle: 'Códigos de recuperación',
          primaryAction: null,
        }) %>

        <div class="mf-workspace-content">
          <div class="mf-form-shell">
            <section class="mf-form-panel">
              <div class="mf-form-panel__header">
                <span class="mf-badge mf-badge--success">MFA habilitado</span>
                <h2 class="mt-3">Guarda tus códigos de recuperación</h2>
                <p>
                  Cada código puede utilizarse una sola vez y se muestra únicamente en esta
                  pantalla.
                </p>
              </div>

              <div class="mf-alert mf-alert--danger" role="alert">
                Guárdalos en un lugar seguro y separado del teléfono donde tienes Authenticator.
              </div>

              <div class="mf-code-grid">
                <% recoveryCodes.forEach((code) => { %>
                  <code class="mf-recovery-code"><%= code %></code>
                <% }) %>
              </div>

              <a class="mf-button mf-button--primary" href="/security">Finalizar</a>
            </section>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
